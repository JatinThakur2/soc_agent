#PBS -e /home/deepak.g/Downloads/soc_agent/jobs/logs/01_engineer.err
#PBS -j oe

PROJECT=/home/deepak.g/Downloads/soc_agent
cd $PROJECT

export PATH=/usr/local/cuda/bin:$PATH
export LD_LIBRARY_PATH=/usr/local/cuda/lib64:$LD_LIBRARY_PATH
export OMP_NUM_THREADS=8

echo "=== Feature Engineering ==="
echo "Node: $(hostname)"
echo "Start: $(date)"

$PROJECT/.venv/bin/python -m src.features.engineer

echo "End: $(date)"
